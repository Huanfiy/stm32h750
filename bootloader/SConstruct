"""
Standalone SCons build for the STM32H750 bootloader.

Not intended to be invoked from the main project's SConstruct -- run it from
this directory (or via ../run.sh boot-build).
"""

import os
import rtconfig

ROOT       = os.path.abspath('..')
HAL_ROOT   = os.path.join(ROOT, 'libraries', 'STM32H7xx_HAL')
HAL_DRV    = os.path.join(HAL_ROOT, 'STM32H7xx_HAL_Driver')
CMSIS_DEV  = os.path.join(HAL_ROOT, 'CMSIS', 'Device', 'ST', 'STM32H7xx')
CUBE_CFG   = os.path.join(ROOT, 'board', 'CubeMX_Config')

env = Environment(
    tools = ['default'],
    ENV   = os.environ,
    CC      = rtconfig.CC,
    AS      = rtconfig.AS,
    AR      = rtconfig.AR,
    LINK    = rtconfig.LINK,
    CFLAGS  = rtconfig.CFLAGS,
    ASFLAGS = rtconfig.AFLAGS,
    ARFLAGS = '-rc',
    LINKFLAGS = rtconfig.LFLAGS,
    CPPDEFINES = rtconfig.CPPDEFINES,
)

if rtconfig.EXEC_PATH:
    env.PrependENVPath('PATH', rtconfig.EXEC_PATH)

env.Append(CPPPATH = [
    'inc',
    os.path.join(CUBE_CFG, 'Core', 'Inc'),
    os.path.join(HAL_DRV, 'Inc'),
    os.path.join(HAL_DRV, 'Inc', 'Legacy'),
    os.path.join(ROOT, 'libraries', 'HAL_Drivers', 'CMSIS', 'Include'),
    os.path.join(CMSIS_DEV, 'Include'),
])

# Bootloader sources
src = Glob('src/*.c')

# Minimum HAL set required for bootloader (UART + QSPI + clock + GPIO + MPU)
hal_modules = [
    'stm32h7xx_hal.c',
    'stm32h7xx_hal_cortex.c',
    'stm32h7xx_hal_rcc.c',
    'stm32h7xx_hal_rcc_ex.c',
    'stm32h7xx_hal_pwr.c',
    'stm32h7xx_hal_pwr_ex.c',
    'stm32h7xx_hal_gpio.c',
    'stm32h7xx_hal_uart.c',
    'stm32h7xx_hal_uart_ex.c',
    'stm32h7xx_hal_qspi.c',
    'stm32h7xx_hal_dma.c',
    'stm32h7xx_hal_dma_ex.c',
    'stm32h7xx_hal_mdma.c',
    'stm32h7xx_hal_exti.c',
]
for m in hal_modules:
    src += [os.path.join(HAL_DRV, 'Src', m)]

# CubeMX system init + GCC startup vector
src += [os.path.join(CUBE_CFG, 'Core', 'Src', 'system_stm32h7xx.c')]
startup = os.path.join(CMSIS_DEV, 'Source', 'Templates', 'gcc', 'startup_stm32h750xx.s')
src += [startup]

target_elf = os.path.join(rtconfig.BUILD_DIR, rtconfig.PROJECT_NAME + '.elf')
target_bin = os.path.join(rtconfig.BUILD_DIR, rtconfig.PROJECT_NAME + '.bin')

VariantDir(rtconfig.BUILD_DIR, '.', duplicate = 0)

# Make sure intermediate objs for files outside the source dir land inside BUILD_DIR too.
# SCons handles this implicitly when the source path is absolute -- the .o lands next to .c.
# We use an explicit Object() pass so .o ends up under BUILD_DIR even for external sources.
objs = []
for s in src:
    s_str = str(s)
    rel = os.path.relpath(s_str, ROOT) if s_str.startswith(ROOT) else os.path.relpath(s_str)
    obj_path = os.path.join(rtconfig.BUILD_DIR, 'objs', rel + '.o')
    objs += env.Object(target = obj_path, source = s_str)

elf = env.Program(target = target_elf, source = objs)

bin_action = env.Command(
    target = target_bin,
    source = elf,
    action = [
        '{objcpy} -O binary $SOURCE $TARGET'.format(objcpy = rtconfig.OBJCPY),
        '{size} $SOURCE'.format(size = rtconfig.SIZE),
    ],
)

Default(bin_action)
